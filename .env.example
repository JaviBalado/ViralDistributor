# =============================================================
# ViralDistributor — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# =============================================================

# --- Web Dashboard Credentials (required) ---
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_me_to_a_strong_password

# --- OAuth Redirect URI ---
# Local development:
OAUTH_REDIRECT_URI=http://localhost:8000/auth/youtube/callback
# Production (Coolify) — uncomment and set your domain:
# OAUTH_REDIRECT_URI=https://your-domain.com/auth/youtube/callback

# --- YouTube / Google Cloud ---
# Path to your OAuth 2.0 client secrets JSON (Web Application type)
YOUTUBE_CLIENT_SECRETS_PATH=auth/client_secrets.json

# --- Database ---
DATABASE_URL=sqlite:///./data/viraldistributor.db

# --- General ---
LOG_LEVEL=INFO
