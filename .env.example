# =============================================================
# ViralDistributor — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# =============================================================

# --- Web Dashboard Credentials (required) ---
# Used for HTTP Basic Auth. Set these in Coolify's Environment Variables UI.
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_me_to_a_strong_password

# --- YouTube / Google Cloud ---
# Path to your OAuth 2.0 client secrets JSON downloaded from Google Cloud Console
YOUTUBE_CLIENT_SECRETS_PATH=auth/client_secrets.json

# Path where the OAuth token will be stored after first authentication
YOUTUBE_TOKEN_PATH=auth/tokens/youtube_token.json

# Default privacy status for uploaded videos: public | private | unlisted
YOUTUBE_DEFAULT_PRIVACY=private

# Default YouTube category ID (22 = People & Blogs, 24 = Entertainment, 28 = Science & Technology)
YOUTUBE_DEFAULT_CATEGORY_ID=22

# Channel ID (optional, for multi-channel setups)
YOUTUBE_CHANNEL_ID=

# --- Instagram (Phase 2 — not yet implemented) ---
# INSTAGRAM_ACCESS_TOKEN=
# INSTAGRAM_BUSINESS_ACCOUNT_ID=

# --- TikTok (Phase 3 — not yet implemented) ---
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# TIKTOK_ACCESS_TOKEN=

# --- General ---
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
