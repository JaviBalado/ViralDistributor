# =============================================================
# ViralDistributor — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# =============================================================

# ── Web Dashboard (required) ─────────────────────────────────
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_me_to_a_strong_password

# ── Base URL (used to auto-build OAuth redirect URIs) ────────
# Local development:
BASE_URL=http://localhost:8000
# Production (Coolify) — set your public domain:
# BASE_URL=https://yourdomain.com

# ── YouTube / Google Cloud ───────────────────────────────────
# Create a project at https://console.cloud.google.com
# Enable "YouTube Data API v3", create OAuth 2.0 credentials (Web application type)
# Add your redirect URI: {BASE_URL}/auth/youtube/callback
#
# Option A — paste client_id and client_secret directly (easiest for Coolify):
YOUTUBE_CLIENT_ID=your_google_client_id_here
YOUTUBE_CLIENT_SECRET=your_google_client_secret_here
#
# Option B — path to the downloaded client_secrets.json file:
# YOUTUBE_CLIENT_SECRETS_PATH=auth/client_secrets.json
#
# Override the redirect URI if needed (defaults to BASE_URL + /auth/youtube/callback):
# OAUTH_REDIRECT_URI=https://yourdomain.com/auth/youtube/callback

# ── TikTok ───────────────────────────────────────────────────
# 1. Create an account at https://developers.tiktok.com
# 2. Create an app → add "Content Posting API" product
# 3. Under "Manage app" add your redirect URI: {BASE_URL}/auth/tiktok/callback
# 4. Copy Client Key and Client Secret from the app dashboard
#
# Scope notes:
#   video.upload  — sends video to creator's inbox (no app review needed, works immediately)
#   video.publish — publishes directly (requires TikTok app review, can take weeks)
# The publisher auto-uses the highest scope available.
#
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here
#
# Override redirect URI if needed (defaults to BASE_URL + /auth/tiktok/callback):
# TIKTOK_REDIRECT_URI=https://yourdomain.com/auth/tiktok/callback

# ── Instagram (via Meta / Facebook) ─────────────────────────
# Requirements:
#   • Instagram account must be Business or Creator type
#   • Instagram account must be linked to a Facebook Page
#     (Instagram app → Settings → Account → Switch to Professional Account,
#      then link to a Facebook Page in Facebook Page Settings)
#
# Steps:
# 1. Go to https://developers.facebook.com and create an app (type: Business)
# 2. Add the "Instagram Graph API" product
# 3. In App Settings → Basic, copy App ID and App Secret
# 4. In Facebook Login → Settings, add your redirect URI: {BASE_URL}/auth/instagram/callback
# 5. Required permissions: instagram_basic, instagram_content_publish,
#    pages_show_list, pages_read_engagement
#    (for test users these work without app review;
#     for production users you need Meta app review)
#
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here
#
# Override redirect URI if needed (defaults to BASE_URL + /auth/instagram/callback):
# INSTAGRAM_REDIRECT_URI=https://yourdomain.com/auth/instagram/callback

# ── Database ─────────────────────────────────────────────────
# SQLite (default, no extra setup needed):
DATABASE_URL=sqlite:///./data/viraldistributor.db
# PostgreSQL example (for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/viraldistributor

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
